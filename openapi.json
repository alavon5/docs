      "Order": { "type": "object", "properties": { "id": { "type": "integer", "example": 1234 }, "invoiceNo": { "type": "integer", "example": 15 }, "created": { "type": "integer", "format": "int64", "example": 1573397217 }, "customerName": { "type": "string", "example": "John Doe" }, "customerEmail": { "type": "string", "format": "email", "example": "john@email.com" }, "contactId": { "type": "integer" }, "memberId": { "type": "integer" }, "shippingAddress": { "$ref": "#/components/schemas/Address" }, "billingAddress": { "$ref": "#/components/schemas/Address" }, "subTotal": { "type": "number", "example": 49 }, "total": { "type": "number", "example": 49 }, "paid": { "type": "boolean" }, "paymentMethod": { "type": "string", "example": "stripe" }, "transactionId": { "type": "string" }, "status": { "type": "string", "enum": ["pending", "shipped", "completed", "canceled", "archived"], "example": "completed" }, "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } }, "tags": { "type": "array", "items": { "type": "string" } }, "additionalFields": { "type": "array", "items": { "$ref": "#/components/schemas/FieldValue" } } } },
      "OrderUpdate": { "type": "object", "properties": { "customerName": { "type": "string" }, "customerEmail": { "type": "string", "format": "email" }, "billingAddress": { "$ref": "#/components/schemas/Address" }, "shippingAddress": { "$ref": "#/components/schemas/Address" }, "paymentMethod": { "type": "string", "example": "stripe" }, "transactionId": { "type": "string" }, "paid": { "type": "boolean" }, "status": { "type": "string", "enum": ["PENDING", "SHIPPED", "COMPLETED", "CANCELED", "ARCHIVED"] }, "notifyCustomer": { "type": "boolean" } } },
      "OrderList": { "allOf": [{ "$ref": "#/components/schemas/PaginationMeta" }, { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Order" } } } }] },
      "FormSubmission": { "type": "object", "properties": { "name": { "type": "string", "example": "Contact form" }, "received": { "type": "integer", "format": "int64", "example": 1573120479 }, "fields": { "type": "array", "items": { "$ref": "#/components/schemas/NameValue" } } } },
      "FormSubmissionList": { "allOf": [{ "$ref": "#/components/schemas/PaginationMeta" }, { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/FormSubmission" } } } }] },
      "Booking": { "type": "object", "properties": { "id": { "type": "integer", "example": 206 }, "eventId": { "type": "integer", "example": 98146 }, "contactId": { "type": "integer", "example": 41 }, "name": { "type": "string", "example": "Jane Doe" }, "email": { "type": "string", "format": "email", "example": "jane@doe.com" }, "start": { "type": "integer", "format": "int64", "example": 1587936600 }, "end": { "type": "integer", "format": "int64", "example": 1587938400 }, "eventData": { "type": "object", "properties": { "name": { "type": "string", "example": "My event" }, "location": { "type": "string", "example": "Skype" } } }, "operator": { "type": "object", "properties": { "id": { "type": "integer", "example": 51215 }, "name": { "type": "string", "example": "John Doe" }, "email": { "type": "string", "format": "email", "example": "john@doe.com" } } }, "formAnswers": { "type": "array", "items": { "$ref": "#/components/schemas/NameValue" } } } },
      "BookingList": { "allOf": [{ "$ref": "#/components/schemas/PaginationMeta" }, { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Booking" } } } }] },
      "SubscriberListInput": { "type": "object", "properties": { "name": { "type": "string", "example": "New List" } }, "required": ["name"] },
      "SubscriberList": { "allOf": [{ "$ref": "#/components/schemas/SubscriberListInput" }, { "type": "object", "properties": { "id": { "type": "integer", "example": 87647751 }, "created": { "type": "integer", "format": "int64", "example": 1613384738 }, "subscribers": { "type": "integer", "example": 25 }, "opens": { "type": "number", "example": 0.85 }, "clicks": { "type": "number", "example": 0.41 } } }] },
      "SubscriberListList": { "allOf": [{ "$ref": "#/components/schemas/PaginationMeta" }, { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriberList" } } } }] },
      "WebhookEvent": { "type": "string", "enum": ["order_created", "order_updated", "product_created", "product_updated", "form_submitted", "contact_updated", "booking_created"] },
      "WebhookInput": { "type": "object", "properties": { "target": { "type": "string", "format": "uri", "example": "https://your-target.com/some-path" }, "secret": { "type": "string", "example": "your-secret" }, "events": { "type": "array", "items": { "$ref": "#/components/schemas/WebhookEvent" }, "example": ["order_created", "order_updated"] } }, "required": ["target", "events"] },
      "Webhook": { "allOf": [{ "$ref": "#/components/schemas/WebhookInput" }, { "type": "object", "properties": { "id": { "type": "string", "example": "rh_24488493954" } } }] },
      "WebsiteRef": { "type": "object", "properties": { "id": { "type": "integer", "example": 123 }, "subdomain": { "type": "string", "example": "some-subdomain" }, "systemDomain": { "type": "string", "example": "your-system.subdomain.com" }, "domain": { "type": "string", "example": "your-primary-domain.com" } } },
      "FormSubmissionWebhook": { "type": "object", "description": "POST payload delivered for the `form_submitted` event.", "properties": { "website": { "$ref": "#/components/schemas/WebsiteRef" }, "contact": { "$ref": "#/components/schemas/Contact" }, "formName": { "type": "string", "example": "Contact Form" }, "formValues": { "type": "array", "items": { "$ref": "#/components/schemas/FieldValue" } } } }
