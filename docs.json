{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Bosscart by Alavon365",
  "description": "Developer documentation for the Bosscart API and related support resources.",
  "colors": {
    "primary": "#003CFE",
    "light": "#FFFFFF",
    "dark": "#15803D"
  },
  "fonts": {
    "family": "Inter"
  },
  "favicon": "https://mintlify.s3.us-west-1.amazonaws.com/alavon365/gradient_icon-6787089.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Builder",
        "groups": [
          {
            "group": "Builder docs",
            "pages": [
              "builder"
            ]
          }
        ]
      },
      {
        "tab": "API Guide",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "api",
              "quickstart"
            ]
          },
          {
            "group": "API guides",
            "pages": [
              "authentication",
              "pagination-and-errors",
              "webhooks-overview"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "support-resources"
            ]
          }
        ]
      },
      {
        "tab": "Endpoints",
        "openapi": {
          "source": "openapi.json",
          "directory": "endpoints"
        }
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Help Center",
          "href": "https://help.alavon365.com/",
          "icon": "circle-question"
        },
        {
          "anchor": "Blog",
          "href": "https://alavon365.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/builder-support",
      "destination": "/builder"
    },
    {
      "source": "/api-reference",
      "destination": "/endpoints"
    },
    {
      "source": "/api-reference/*",
      "destination": "/endpoints/*"
    },
    {
      "source": "/api/*",
      "destination": "/endpoints/*"
    }
  ],
  "logo": {
    "light": "/logo/bosscart%20main.png",
    "dark": "/logo/bosscart%20white.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://help.alavon365.com/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://bosscart.io/login"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/alavon365",
      "github": "https://github.com/alavon5/docs",
      "linkedin": "https://linkedin.com/company/alavon356"
    }
  }
}
